    "price_per_kwp_with_vat": {
      "type": "number",
      "description": "\u05de\u05d7\u05d9\u05e8 \u05dc-kWp (\u05db\u05d5\u05dc\u05dc \u05de\u05e2\"\u05de)"
    },
    "total_price": {
      "type": "number",
      "description": "\u05de\u05d7\u05d9\u05e8 \u05db\u05d5\u05dc\u05dc (\u05db\u05d5\u05dc\u05dc \u05de\u05e2\"\u05de)"
    },
    "total_price_no_vat": {
      "type": "number",
      "description": "\u05de\u05d7\u05d9\u05e8 \u05db\u05d5\u05dc\u05dc (\u05dc\u05dc\u05d0 \u05de\u05e2\"\u05de)"
    },
    "deposit_amount": {
      "type": "number",
      "description": "\u05e1\u05db\u05d5\u05dd \u05de\u05e7\u05d3\u05de\u05d4"
    },
