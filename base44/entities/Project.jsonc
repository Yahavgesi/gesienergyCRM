    "assigned_agent": {
      "type": "string",
      "description": "\u05e1\u05d5\u05db\u05df \u05de\u05db\u05d9\u05e8\u05d5\u05ea"
    },
    "assigned_installer": {
      "type": "string",
      "description": "\u05de\u05ea\u05e7\u05d9\u05df"
    },
    "assigned_team": {
      "type": "string",
      "description": "\u05e6\u05d5\u05d5\u05ea"
    },
    "current_step": {
      "type": "string",
      "description": "\u05e9\u05dc\u05d1 \u05e0\u05d5\u05db\u05d7\u05d9"
    },
    "current_step_index": {
      "type": "number",
      "default": 0,
