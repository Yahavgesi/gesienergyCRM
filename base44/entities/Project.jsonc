    },
    "type": {
      "type": "string",
      "enum": [
        "residential",
        "commercial",
        "industrial",
        "agricultural",
        "tender"
      ],
      "description": "\u05e1\u05d5\u05d2 \u05e4\u05e8\u05d5\u05d9\u05e7\u05d8"
    },
    "address": {
      "type": "string",
      "description": "\u05db\u05ea\u05d5\u05d1\u05ea \u05d4\u05ea\u05e7\u05e0\u05d4"
    },
    "city": {
      "type": "string",
      "description": "\u05e2\u05d9\u05e8"
    },
    "region": {
      "type": "string",
      "description": "\u05d0\u05d6\u05d5\u05e8"
    },
    "kwp": {
      "type": "number",
      "description": "\u05d2\u05d5\u05d3\u05dc \u05de\u05e2\u05e8\u05db\u05ea (kWp)"
