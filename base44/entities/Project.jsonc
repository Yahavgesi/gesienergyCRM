    "num_panels": {
      "type": "number",
      "description": "\u05de\u05e1\u05e4\u05e8 \u05e4\u05d0\u05e0\u05dc\u05d9\u05dd"
    },
    "panel_brand": {
      "type": "string",
      "description": "\u05d9\u05e6\u05e8\u05df \u05e4\u05d0\u05e0\u05dc\u05d9\u05dd"
    },
    "panel_model": {
      "type": "string",
      "description": "\u05d3\u05d2\u05dd \u05e4\u05d0\u05e0\u05dc\u05d9\u05dd"
    },
    "inverter_brand": {
      "type": "string",
      "description": "\u05d9\u05e6\u05e8\u05df \u05de\u05d4\u05e4\u05da"
    },
    "inverter_model": {
      "type": "string",
      "description": "\u05d3\u05d2\u05dd \u05de\u05d4\u05e4\u05da"
    },
    "has_battery": {
      "type": "boolean",
      "default": false,
      "description": "\u05db\u05d5\u05dc\u05dc \u05e1\u05d5\u05dc\u05dc\u05d4"
    },
    "battery_brand": {
      "type": "string",
      "description": "\u05d9\u05e6\u05e8\u05df \u05e1\u05d5\u05dc\u05dc\u05d4"
    },
